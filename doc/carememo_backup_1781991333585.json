    "conditionAtVisits": [
        {
            "id": 1,
            "personId": 1,
            "title": "タイトルあ１２３４５ＡＢＣＤＥ",
            "condition": "記録1",
            "author": "佐藤",
            "recordTime": "2023-01-01T12:00:00Z"
        },
        {
            "id": 2,
            "personId": 1,
            "title": "タイトル1【◯】良い例",
            "condition": "昼食時、Aさんは鮭の切り身をゆっくりと二口食べたが、その後箸を置いた。約5分後、残っている鮭を指し、『これはもう少し食べられそうですか？』と声をかけた。硬い表情で『いらない』とおっしゃったので、お皿を下げた。",
            "author": "佐藤",
            "recordTime": "2023-02-01T12:00:00Z"
        },
        {
            "id": 3,
            "personId": 1,
            "title": "タイトル1【×】悪い例",
            "condition": "食が進まない様子だった。昼食中に『これもう少し食べられますか？』と言い、『いらない』と返した。",
            "author": "鈴木",
            "recordTime": "2023-03-01T12:00:00Z"
        },
        {
            "id": 4,
            "personId": 1,
            "title": "タイトル1【◯】良い例",
            "condition": "前回の排泄から◯時間経過していたので、「トイレに行きましょう」と声をかけた。トイレでおむつを確認すると失禁していたので、新しいおむつと交換した。トイレへ誘導する間隔を短くするべきか要検討。",
            "author": "鈴木",
            "recordTime": "2023-04-01T12:00:00Z"
        },
        {
            "id": 5,
            "personId": 1,
            "title": "タイトル1【×】悪い例",
            "condition": "トイレに誘導しようとしたが、すでにおむつが汚れていたので交換した。",
            "author": "高橋",
            "recordTime": "2023-05-01T12:00:00Z"
        },
        {
            "id": 6,
            "personId": 1,
            "title": "タイトル1【◯】良い例",
            "condition": "居室に入ると、Aさんがベッドの横の床の上で座り込んでいた。すぐに『大丈夫ですか？』と声をかけると、『リビングに行こうとしたらうまく立ち上がれなかった』と返答があった。打撲や痛みはないと答えられたので、リビングまで同行した。",
            "author": "高橋",
            "recordTime": "2023-06-01T12:00:00Z"
        },
        {
            "id": 7,
            "personId": 1,
            "title": "タイトル1【×】悪い例",
            "condition": "昼過ぎに居室で転倒。",
            "author": "田中",
            "recordTime": "2023-07-01T12:00:00Z"
        },
        {
            "id": 8,
            "personId": 1,
            "title": "タイトル1",
            "condition": "記録1\nあいうえお 訪問時 発熱 今朝の薬 飲み忘れ あり 今朝の薬は飲み忘れていました 訪問した時に薬を飲むように進め 12時35分に朝分の薬を飲みました 土曜日と日曜日もヘルパーの訪問の希望があったので会社に戻ってからヘルパーの調整をします",
            "author": "田中",
            "recordTime": "2023-08-01T12:00:00Z"
